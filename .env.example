# LLM 配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL= your_mmodel_name_here
EMBEDDING_MODEL=your_mmodel_name_here
COVER_VISION_MODEL=your_mmodel_name_here

# DashScope ASR（语音识别，可选）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ASR_TIMEOUT=600

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/bilibili_rag.db

# B站 Cookie AES-256-GCM 加密。无密钥时系统拒绝持久化新的登录态，绝不降级明文。
# 生成示例：python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
BILIBILI_COOKIE_ENCRYPTION_KEYS=v1=replace_with_urlsafe_base64_32_byte_key
BILIBILI_COOKIE_ACTIVE_KEY_ID=v1

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# 多Agent系统配置
SHORT_TERM_MEMORY_MAX_SIZE=1000
SHORT_TERM_MEMORY_TTL_HOURS=24
LONG_TERM_MEMORY_THRESHOLD=3
RECOMMENDATION_CHECK_INTERVAL_MINUTES=60
MAX_RECOMMENDATIONS=10
# 推荐主链路版本；用于批次追踪和后续实验对比
RECOMMENDATION_ALGORITHM_VERSION=temporal-ontology-xmix-v2
# 默认关闭。开启后仅对规则排序后的少量候选做 25% 权重辅助重排
RECOMMENDATION_LLM_RERANK_ENABLED=false
RECOMMENDATION_LLM_TOP_N=20
RECOMMENDATION_LLM_TIMEOUT_SECONDS=15
# 近期曝光去重窗口和单批次同 UP 主上限
RECOMMENDATION_RECENT_EXPOSURE_DAYS=7
RECOMMENDATION_MAX_PER_UP=2
RECOMMENDATION_PROFILE_MAX_AGE_HOURS=24
# JSON；键必须与 app/services/recommendation/ranking.py 一致，权重建议总和为 1
RECOMMENDATION_SCORING_WEIGHTS={"content_match":0.18,"ontology_match":0.17,"recent_interest":0.16,"multi_interest":0.10,"up_affinity":0.10,"freshness":0.09,"quality":0.08,"exploration":0.07,"context":0.05}
# V2 独立灰度开关；评估达标前默认关闭
TEMPORAL_AFFINITY_V2_ENABLED=false
TEMPORAL_AFFINITY_TAU=1.5
TEMPORAL_SECONDARY_SIGNAL_DISCOUNT=0.25
INTEREST_CLUSTER_MAX_HOPS=1
MULTI_INTEREST_TEMPERATURE=0.35
RAG_GROUNDED_V2_ENABLED=false
RAG_ORIGINAL_MIN_RELEVANCE=0.35
RAG_SYNONYM_MIN_RELEVANCE=0.45
RAG_HIERARCHY_MIN_RELEVANCE=0.55
RAG_ASSOCIATIVE_MIN_RELEVANCE=0.65
RAG_RETRIEVAL_POOL_SIZE=30
RAG_RERANKER_ENABLED=true
RAG_RERANKER_MAX_CHUNKS=30
RAG_ANSWERABILITY_THRESHOLD=0.45
RAG_ANSWERABILITY_QUERY_COVERAGE=0.28
RAG_SUBTITLE_CHUNK_SECONDS=45
PROFILE_SYNC_V2_ENABLED=false
ONTOLOGY_LINKER_V2_ENABLED=false
ONTOLOGY_LINKER_ACCEPT_THRESHOLD=0.78
ONTOLOGY_LINKER_AMBIGUITY_MARGIN=0.08
CANDIDATE_HYDRATION_ENABLED=false
# 灰度比例：先用 V2_TEST_SESSION_HASHES 指定测试账号，再依次设置 10/50/100
V2_ROLLOUT_PERCENTAGE=0
V2_TEST_SESSION_HASHES=
UP_VIDEO_CACHE_TTL_SECONDS=900
CANDIDATE_HYDRATION_CACHE_TTL_SECONDS=1800
CANDIDATE_HYDRATION_CONCURRENCY=8
CANDIDATE_HYDRATION_TIMEOUT_SECONDS=12
RECOMMENDATION_BASELINE_ALGORITHM_VERSION=temporal-ontology-xmix-v2
SCHEDULER_TIMEZONE=Asia/Shanghai
WS_HEARTBEAT_INTERVAL=30
