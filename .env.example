# LLM 配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL= your_mmodel_name_here
EMBEDDING_MODEL=your_mmodel_name_here
COVER_VISION_MODEL=your_mmodel_name_here

# DashScope ASR（语音识别，可选）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ASR_TIMEOUT=600

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/bilibili_rag.db

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# 多Agent系统配置
SHORT_TERM_MEMORY_MAX_SIZE=1000
SHORT_TERM_MEMORY_TTL_HOURS=24
LONG_TERM_MEMORY_THRESHOLD=3
RECOMMENDATION_CHECK_INTERVAL_MINUTES=60
MAX_RECOMMENDATIONS=10
SCHEDULER_TIMEZONE=Asia/Shanghai
WS_HEARTBEAT_INTERVAL=30
